            },
            {
              "name": "apikey",
              "value": "generate_a_secure_api_key_here"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"number\": \"{{$node[\"Supabase\"].json.telefone}}\",\n  \"text\": \"{{$json.output}}\"\n}",
        "options": {}
      },
      "id": "784f18ba-1a5c-48be-a690-bd3d2d4f2e9b",
      "name": "HTTP Request (Evolution API WhatsApp)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        950,
